# Existing Supabase project (server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Existing Stripe account
STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_webhook_secret

# Comma-separated Supabase Auth users allowed into /admin
ADMIN_EMAILS=owner@example.com

# Canonical production URL (Vercel previews use VERCEL_URL automatically)
SITE_URL=https://your-live-domain.example

# Optional buyer delivery email through the existing/new Resend account
RESEND_API_KEY=
RESEND_FROM_EMAIL=ShadowGLB <delivery@your-domain.example>

# Optional; defaults to shadowglb-media
SUPABASE_MEDIA_BUCKET=shadowglb-media
